{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
      "rootDir": "src",
    "outDir": "dist",
      "experimentalDecorators": true,//for di container-inversify
  "emitDecoratorMetadata": true,//for di container-inversify
  },
  "include": ["src"]
  
}

