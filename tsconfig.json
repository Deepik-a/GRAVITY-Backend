//to change ts to js

{
  "compilerOptions": {
    "target": "ES2020",

    /* 🔑 Switch to CommonJS */
    "module": "CommonJS",
    "moduleResolution": "Node",

    "rootDir": "src",
    "outDir": "dist",

    /* Path alias still works (compile-time) */
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"]
    },

    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src"]
}
